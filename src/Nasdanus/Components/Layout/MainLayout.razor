@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Dense="true" Class="app-bar">
        <MudIcon Icon="@Icons.Material.Filled.RestaurantMenu" Class="app-logo" />
        <MudText Typo="Typo.h6" Class="app-title">Nasdanus</MudText>
        <MudSpacer />
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudButton Href="/" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Home">Avui</MudButton>
            <MudButton Href="/recipes" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.MenuBook">Receptes</MudButton>
            <MudButton Href="/planner" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.CalendarMonth">Planner</MudButton>
            <MudButton Href="/shopping" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.ShoppingCart">Compra</MudButton>
            <MudButton Href="/pantry" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Inventory2">Rebost</MudButton>
        </MudHidden>
    </MudAppBar>

    <MudMainContent Class="main-content">
        @Body
    </MudMainContent>

    <MudHidden Breakpoint="Breakpoint.MdAndUp">
        <nav class="bottom-nav" aria-label="Navegacio principal">
            <MudIconButton Href="/" Icon="@Icons.Material.Filled.Home" Color="Color.Primary" aria-label="Avui" />
            <MudIconButton Href="/recipes" Icon="@Icons.Material.Filled.MenuBook" Color="Color.Primary" aria-label="Receptes" />
            <MudIconButton Href="/planner" Icon="@Icons.Material.Filled.CalendarMonth" Color="Color.Primary" aria-label="Planner" />
            <MudIconButton Href="/shopping" Icon="@Icons.Material.Filled.ShoppingCart" Color="Color.Primary" aria-label="Compra" />
            <MudIconButton Href="/pantry" Icon="@Icons.Material.Filled.Inventory2" Color="Color.Primary" aria-label="Rebost" />
        </nav>
    </MudHidden>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#3891a6",
            Secondary = "#c2412d",
            Tertiary = "#2f6f9f",
            Background = "#f7f8f4",
            Surface = "#ffffff",
            AppbarBackground = "#ffffff",
            AppbarText = "#24342d",
            TextPrimary = "#1f2a25",
            TextSecondary = "#66746d"
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "8px"
        }
    };
}
