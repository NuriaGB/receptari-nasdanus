@using Nasdanus.Domain
@inject IDialogService DialogService

<MudStack Spacing="1" Class="meal-slot-selector">
    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="meal-slot-title">
        <MudText Typo="Typo.subtitle2">@Slot.MealKind.ToDisplayName()</MudText>
        <MudButton OnClick="OpenPickerAsync"
                   Variant="Variant.Text"
                   Color="Color.Primary"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Add">
            Afegir plat
        </MudButton>
    </MudStack>

    @if (PlannedRecipes.Count == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">Sense recepta</MudText>
    }
    else
    {
        <MudStack Spacing="1">
            @foreach (var plannedRecipe in PlannedRecipes)
            {
                <div class="planned-recipe-row">
                    <MudText Typo="Typo.body2" Class="planned-recipe-name">
                        @plannedRecipe.Recipe?.Name
                    </MudText>
                    <div class="planned-recipe-actions">
                        <MudButton Href="@($"/recipes/{plannedRecipe.RecipeId}")"
                                   Variant="Variant.Text"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.OpenInNew">
                            Obrir
                        </MudButton>
                        <MudIconButton OnClick="@(() => RemoveRecipe.InvokeAsync(plannedRecipe.Id))"
                                       Icon="@Icons.Material.Filled.Close"
                                       Color="Color.Secondary"
                                       Size="Size.Small"
                                       aria-label="Treure plat" />
                    </div>
                </div>
            }
        </MudStack>
    }
</MudStack>

@code {
    [Parameter, EditorRequired]
    public MealPlanSlot Slot { get; set; } = default!;

    [Parameter, EditorRequired]
    public IReadOnlyList<Recipe> Recipes { get; set; } = [];

    [Parameter]
    public EventCallback<(DateOnly Date, MealKind MealKind, int RecipeId)> AddRecipe { get; set; }

    [Parameter]
    public EventCallback<int> RemoveRecipe { get; set; }

    private IReadOnlyList<MealPlanRecipe> PlannedRecipes => Slot.PlannedRecipes
        .OrderBy(plannedRecipe => plannedRecipe.Order)
        .ToList();

    private async Task OpenPickerAsync()
    {
        var parameters = new DialogParameters<MealRecipePickerDialog>
        {
            { dialog => dialog.Recipes, Recipes }
        };
        var options = new DialogOptions
        {
            CloseButton = true,
            FullWidth = true,
            MaxWidth = MaxWidth.Small
        };

        var dialog = await DialogService.ShowAsync<MealRecipePickerDialog>("Afegir plat", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is int recipeId)
        {
            await AddRecipe.InvokeAsync((Slot.Date, Slot.MealKind, recipeId));
        }
    }
}
