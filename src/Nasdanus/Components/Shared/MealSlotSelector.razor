@using Nasdanus.Domain
@inject IDialogService DialogService

<MudStack Spacing="1" Class="meal-slot-selector">
    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="meal-slot-title">
        <div class="meal-slot-heading">
            <MudIcon Icon="@MealIcon" Color="Color.Primary" Size="Size.Small" />
            <MudText Typo="Typo.subtitle2">@Slot.MealKind.ToDisplayName()</MudText>
        </div>
        <MudButton OnClick="OpenPickerAsync"
                   Variant="Variant.Text"
                   Color="Color.Primary"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Add">
            Afegir plat
        </MudButton>
    </MudStack>

    @if (PlannedRecipes.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="empty-meal-text">Sense recepta</MudText>
    }
    else
    {
        <MudStack Spacing="1">
            @foreach (var plannedRecipe in PlannedRecipes)
            {
                <div class="planned-recipe-row">
                    <span class="planned-recipe-name" title="@plannedRecipe.Recipe?.Name">
                        @plannedRecipe.Recipe?.Name
                    </span>
                    <MudText Typo="Typo.caption" Class="planned-recipe-servings">
                        @PlannedServingsText(plannedRecipe)
                    </MudText>
                    <div class="planned-recipe-actions">
                        <MudIconButton Href="@($"recipes/{plannedRecipe.RecipeId}?plannedMealId={plannedRecipe.Id}")"
                                       Icon="@Icons.Material.Filled.OpenInNew"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       aria-label="Obrir recepta" />
                        <MudIconButton OnClick="@(() => OpenReplacementPickerAsync(plannedRecipe))"
                                       Icon="@Icons.Material.Filled.SwapHoriz"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       aria-label="Substituir plat" />
                        <MudIconButton OnClick="@(() => RemoveRecipe.InvokeAsync(plannedRecipe.Id))"
                                       Icon="@Icons.Material.Filled.Close"
                                       Color="Color.Secondary"
                                       Size="Size.Small"
                                       aria-label="Treure plat" />
                    </div>
                </div>
            }
        </MudStack>
        <MudText Typo="Typo.caption" Class="meal-nutrition-summary">
            @NutritionService.CompactNutritionText(MealNutrition.Totals)
        </MudText>
        @if (MealNutrition.Totals.HasMissingData)
        {
            <MudText Typo="Typo.caption" Class="nutrition-warning">
                Some ingredients are missing nutrition data.
            </MudText>
        }
    }
</MudStack>

@code {
    [Parameter, EditorRequired]
    public MealPlanSlot Slot { get; set; } = default!;

    [Parameter, EditorRequired]
    public IReadOnlyList<Recipe> Recipes { get; set; } = [];

    [Parameter]
    public EventCallback<(DateOnly Date, MealKind MealKind, PlannedRecipeSelection Selection)> AddRecipe { get; set; }

    [Parameter]
    public EventCallback<int> RemoveRecipe { get; set; }

    [Parameter]
    public EventCallback<(int PlannedRecipeId, PlannedRecipeSelection Selection)> ReplaceRecipe { get; set; }

    private IReadOnlyList<MealPlanRecipe> PlannedRecipes => Slot.PlannedRecipes
        .OrderBy(plannedRecipe => plannedRecipe.Order)
        .ToList();
    private MealNutritionSummary MealNutrition => NutritionService.CalculateMeal(Slot);
    private string MealIcon => Slot.MealKind == MealKind.Lunch
        ? Icons.Material.Filled.Restaurant
        : Icons.Material.Filled.DarkMode;
    private static string PlannedServingsText(MealPlanRecipe plannedRecipe)
    {
        var servings = PlannedServingsValue(plannedRecipe);
        return servings > 0 ? $"{servings} rac." : "Racions?";
    }

    private async Task OpenPickerAsync()
    {
        var parameters = new DialogParameters<MealRecipePickerDialog>
        {
            { dialog => dialog.Recipes, Recipes },
            { dialog => dialog.SlotMealKind, Slot.MealKind }
        };
        var options = new DialogOptions
        {
            CloseButton = true,
            FullWidth = true,
            MaxWidth = MaxWidth.Small
        };

        var dialog = await DialogService.ShowAsync<MealRecipePickerDialog>("Afegir plat", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is PlannedRecipeSelection selection)
        {
            await AddRecipe.InvokeAsync((Slot.Date, Slot.MealKind, selection));
        }
    }

    private async Task OpenReplacementPickerAsync(MealPlanRecipe plannedRecipe)
    {
        var parameters = new DialogParameters<MealRecipePickerDialog>
        {
            { dialog => dialog.Recipes, Recipes },
            { dialog => dialog.SlotMealKind, Slot.MealKind },
            { dialog => dialog.InitialServings, PlannedServingsValue(plannedRecipe) },
            { dialog => dialog.ActionLabel, "Substituir" },
            { dialog => dialog.ShowQuickAdd, false }
        };
        var options = new DialogOptions
        {
            CloseButton = true,
            FullWidth = true,
            MaxWidth = MaxWidth.Small
        };

        var dialog = await DialogService.ShowAsync<MealRecipePickerDialog>("Substituir plat", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is PlannedRecipeSelection selection)
        {
            await ReplaceRecipe.InvokeAsync((plannedRecipe.Id, selection));
        }
    }

    private static int PlannedServingsValue(MealPlanRecipe plannedRecipe)
    {
        if (plannedRecipe.PlannedServings > 0)
        {
            return plannedRecipe.PlannedServings;
        }

        return plannedRecipe.Recipe?.Servings > 0 ? plannedRecipe.Recipe.Servings : 3;
    }
}
