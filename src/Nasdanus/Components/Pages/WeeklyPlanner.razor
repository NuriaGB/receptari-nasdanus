@page "/planner"
@using System.Globalization
@inject PlannerService Planner
@inject RecipeService Recipes

<PageTitle>Nasdanus - Planner</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="page-shell planner-shell">
    <MudStack Spacing="3">
        <div class="page-heading planner-heading">
            <div>
                <MudText Typo="Typo.overline">Planner</MudText>
                <MudText Typo="Typo.h3">Setmana @WeekNumber</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@WeekRangeText</MudText>
            </div>
            <MudStack Row Spacing="1" Class="planner-week-nav">
                <MudButton OnClick="PreviousWeekAsync"
                           Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.ChevronLeft">
                    Setmana anterior
                </MudButton>
                <MudButton OnClick="NextWeekAsync"
                           Variant="Variant.Outlined"
                           Color="Color.Primary"
                           EndIcon="@Icons.Material.Filled.ChevronRight">
                    Setmana següent
                </MudButton>
            </MudStack>
        </div>

        @if (_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else
        {
            <section class="recipe-ideas-section" aria-labelledby="recipe-ideas-title">
                <div class="recipe-ideas-header">
                    <MudText Typo="Typo.h5" id="recipe-ideas-title">Recipe Ideas</MudText>
                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">@RecipeIdeas.Count idees</MudChip>
                </div>

                @if (RecipeIdeas.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Totes les receptes visibles ja estan assignades aquesta setmana.</MudText>
                }
                else
                {
                    <div class="recipe-ideas-list">
                        @foreach (var recipe in RecipeIdeas)
                        {
                            <div class="recipe-idea-chip">
                                <span class="recipe-idea-name" title="@recipe.Name">@recipe.Name</span>
                                <MudIconButton OnClick="@(() => DismissRecipeIdeaAsync(recipe.Id))"
                                               Icon="@Icons.Material.Filled.Close"
                                               Color="Color.Secondary"
                                               Size="Size.Small"
                                               aria-label="Treure idea" />
                            </div>
                        }
                    </div>
                }
            </section>

            <div class="planner-grid" role="list">
                @foreach (var day in _days)
                {
                    <MudPaper Class="planner-day-card" Elevation="0" role="listitem">
                        <div class="planner-day-header">
                            <MudText Typo="Typo.subtitle1">@FormatDay(day.Date)</MudText>
                            @if (day.Date == _today)
                            {
                                <MudChip T="string" Color="Color.Secondary" Size="Size.Small">Avui</MudChip>
                            }
                        </div>

                        <MealSlotSelector Slot="@day.Lunch" Recipes="_recipes" AddRecipe="AddRecipeAsync" RemoveRecipe="RemoveRecipeAsync" ReplaceRecipe="ReplaceRecipeAsync" />
                        <MealSlotSelector Slot="@day.Dinner" Recipes="_recipes" AddRecipe="AddRecipeAsync" RemoveRecipe="RemoveRecipeAsync" ReplaceRecipe="ReplaceRecipeAsync" />
                        <NutritionSummary Title="Total dia"
                                          Subtitle="Dinar + sopar"
                                          Totals="@DayNutritionTotals(day)"
                                          Dense="true" />
                    </MudPaper>
                }
            </div>
        }
    </MudStack>
</MudContainer>

@code {
    private static readonly CultureInfo Catalan = CultureInfo.GetCultureInfo("ca-ES");

    private DateOnly _today;
    private DateOnly _weekStart;
    private List<DayPlan> _days = [];
    private List<Recipe> _recipes = [];
    private HashSet<int> _plannedRecipeIds = [];
    private HashSet<int> _dismissedRecipeIdeaIds = [];
    private bool _isLoading = true;

    private int WeekNumber => ISOWeek.GetWeekOfYear(_weekStart.ToDateTime(TimeOnly.MinValue));
    private string WeekRangeText => $"{_weekStart.ToString("d/M", CultureInfo.InvariantCulture)} - {_weekStart.AddDays(6).ToString("d/M/yyyy", CultureInfo.InvariantCulture)}";
    private IReadOnlyList<Recipe> RecipeIdeas => _recipes
        .Where(recipe => !_plannedRecipeIds.Contains(recipe.Id))
        .Where(recipe => !_dismissedRecipeIdeaIds.Contains(recipe.Id))
        .OrderBy(recipe => recipe.Name)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        _today = DateOnly.FromDateTime(DateTime.Today);
        _weekStart = PlannerService.WeekStart(_today);
        _recipes = await Recipes.GetAllAsync();
        await LoadWeekAsync();
        _isLoading = false;
    }

    private async Task LoadWeekAsync()
    {
        _days = await Planner.GetWeekAsync(_weekStart);
        _plannedRecipeIds = _days
            .SelectMany(day => day.Lunch.PlannedRecipes.Concat(day.Dinner.PlannedRecipes))
            .Select(plannedRecipe => plannedRecipe.RecipeId)
            .ToHashSet();
        _dismissedRecipeIdeaIds = await Planner.GetDismissedRecipeIdeaIdsAsync(_weekStart);
    }

    private async Task AddRecipeAsync((DateOnly Date, MealKind MealKind, PlannedRecipeSelection Selection) change)
    {
        await Planner.AddRecipeAsync(change.Date, change.MealKind, change.Selection.RecipeId, change.Selection.PlannedServings);
        _recipes = await Recipes.GetAllAsync();
        await LoadWeekAsync();
    }

    private async Task RemoveRecipeAsync(int plannedRecipeId)
    {
        await Planner.RemoveRecipeAsync(plannedRecipeId);
        await LoadWeekAsync();
    }

    private async Task ReplaceRecipeAsync((int PlannedRecipeId, PlannedRecipeSelection Selection) change)
    {
        await Planner.ReplaceRecipeAsync(change.PlannedRecipeId, change.Selection.RecipeId, change.Selection.PlannedServings);
        await LoadWeekAsync();
    }

    private async Task DismissRecipeIdeaAsync(int recipeId)
    {
        await Planner.DismissRecipeIdeaAsync(_weekStart, recipeId);
        _dismissedRecipeIdeaIds = await Planner.GetDismissedRecipeIdeaIdsAsync(_weekStart);
    }

    private async Task PreviousWeekAsync()
    {
        _weekStart = _weekStart.AddDays(-7);
        await LoadWeekAsync();
    }

    private async Task NextWeekAsync()
    {
        _weekStart = _weekStart.AddDays(7);
        await LoadWeekAsync();
    }

    private static string FormatDay(DateOnly date) => date.ToString("ddd d/M", Catalan);

    private static NutritionTotals DayNutritionTotals(DayPlan day)
    {
        var totals = new NutritionTotals();
        totals.Add(NutritionService.CalculateMeal(day.Lunch).Totals);
        totals.Add(NutritionService.CalculateMeal(day.Dinner).Totals);
        return totals;
    }
}
