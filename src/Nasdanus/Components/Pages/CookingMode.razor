@page "/cook/{Id:int}"
@inject RecipeService Recipes
@inject PlannerService Planner
@inject IJSRuntime JS

<PageTitle>@(_recipe is null ? "Cuinar" : $"Cuinar - {_recipe.Name}")</PageTitle>

<NavigationLock ConfirmExternalNavigation="@HasUnfinishedSession"
                OnBeforeInternalNavigation="ConfirmInternalNavigationAsync" />

<MudContainer MaxWidth="MaxWidth.Medium" Class="page-shell cooking-shell">
    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_recipe is null || OrderedSteps.Count == 0)
    {
        <MudAlert Severity="Severity.Warning">Aquesta recepta no té passos per cuinar.</MudAlert>
    }
    else
    {
        var step = CurrentStep;

        <MudStack Spacing="3" Class="cook-stack">
            <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="cook-topbar">
                <MudButton Href="@RecipeHref"
                           Variant="Variant.Text"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.ArrowBack">
                    Recepta
                </MudButton>
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">@CompletedCount/@OrderedSteps.Count completats</MudChip>
            </MudStack>

            <div class="cook-heading">
                <MudText Typo="Typo.h5">@_recipe.Name</MudText>
                <MudText Typo="Typo.subtitle1">Pas @(_currentIndex + 1) de @OrderedSteps.Count</MudText>
                <div class="cook-serving-control">
                    @if (IsPlannedContext)
                    {
                        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Groups">
                            @_displayServings racions planificades
                        </MudChip>
                    }
                    else
                    {
                        <MudNumericField T="int"
                                         Label="Racions"
                                         @bind-Value="_displayServings"
                                         Min="1"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Adornment="Adornment.Start"
                                         AdornmentIcon="@Icons.Material.Filled.Groups" />
                    }
                </div>
                <MudProgressLinear Value="@ProgressValue" Color="Color.Primary" Rounded="true" Class="cook-progress" />
            </div>

            <MudPaper Class="@CurrentStepClass" Elevation="0">
                <MudStack Spacing="3">
                    <MudText Typo="Typo.h4">@step.Title</MudText>
                    <MudText Typo="Typo.body1" Class="cook-instruction">@step.Instruction</MudText>
                    @if (step.IngredientReferences.Count > 0)
                    {
                        <div class="cook-step-ingredients">
                            <MudText Typo="Typo.subtitle2">Ingredients per aquest pas</MudText>
                            <MudList T="RecipeStepIngredientReference" Dense="true" Class="cook-step-ingredient-list">
                                @foreach (var reference in step.IngredientReferences.OrderBy(reference => reference.Order))
                                {
                                    <MudListItem Icon="@Icons.Material.Filled.FiberManualRecord">
                                        @reference.ToDisplayText(ScaleFactor)
                                    </MudListItem>
                                }
                            </MudList>
                        </div>
                    }
                    <StepTimer Minutes="@step.TimerMinutes" @key="step.Id" />
                    @if (_isFinished)
                    {
                        <MudAlert Severity="Severity.Success">Recepta finalitzada.</MudAlert>
                    }
                </MudStack>
            </MudPaper>

            <MudGrid Spacing="2" Class="cook-actions">
                <MudItem xs="6" sm="4">
                    <MudButton OnClick="PreviousStep"
                               Disabled="@IsFirstStep"
                               FullWidth="true"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.ArrowBack">
                        Anterior
                    </MudButton>
                </MudItem>
                <MudItem xs="12" sm="4" Class="complete-action">
                    <MudButton OnClick="CompleteCurrentStep"
                               Disabled="@IsCompleteActionDisabled"
                               FullWidth="true"
                               Variant="Variant.Filled"
                               Color="Color.Secondary"
                               Size="Size.Large"
                               StartIcon="@CompleteActionIcon">
                        @CompleteActionLabel
                    </MudButton>
                </MudItem>
                <MudItem xs="6" sm="4">
                    <MudButton OnClick="NextStep"
                               Disabled="@IsLastStep"
                               FullWidth="true"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Large"
                               EndIcon="@Icons.Material.Filled.ArrowForward">
                        Següent
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudStack>
    }
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    [SupplyParameterFromQuery(Name = "plannedMealId")]
    public int? PlannedMealId { get; set; }

    [SupplyParameterFromQuery(Name = "servings")]
    public int? QueryServings { get; set; }

    private Recipe? _recipe;
    private MealPlanRecipe? _plannedRecipe;
    private bool _isLoading = true;
    private bool _isFinished;
    private int _currentIndex;
    private int _displayServings = 1;
    private readonly HashSet<int> _completedStepIds = [];

    private List<RecipeStep> OrderedSteps => _recipe?.Steps.OrderBy(step => step.Order).ToList() ?? [];
    private RecipeStep CurrentStep => OrderedSteps[_currentIndex];
    private int CompletedCount => _completedStepIds.Count;
    private bool IsFirstStep => _currentIndex == 0;
    private bool IsLastStep => _currentIndex == OrderedSteps.Count - 1;
    private bool IsCurrentStepCompleted => _completedStepIds.Contains(CurrentStep.Id);
    private bool IsPlannedContext => _plannedRecipe is not null;
    private decimal ScaleFactor => _recipe is null ? 1 : IngredientScaling.ScaleFactor(_recipe.Servings, _displayServings);
    private string RecipeHref => _recipe is null
        ? "recipes"
        : IsPlannedContext
            ? $"recipes/{_recipe.Id}?plannedMealId={_plannedRecipe!.Id}"
            : $"recipes/{_recipe.Id}?servings={_displayServings}";
    private bool HasUnfinishedSession => !_isLoading && !_isFinished && OrderedSteps.Count > 0 && CompletedCount < OrderedSteps.Count;
    private bool IsCompleteActionDisabled => _isFinished || (!IsLastStep && IsCurrentStepCompleted);
    private string CompleteActionLabel => _isFinished
        ? "Finalitzat"
        : IsLastStep
            ? "Finalitzar recepta"
            : IsCurrentStepCompleted
                ? "Completat"
                : "Completar";
    private string CompleteActionIcon => IsLastStep ? Icons.Material.Filled.Flag : Icons.Material.Filled.CheckCircle;
    private double ProgressValue => OrderedSteps.Count == 0 ? 0 : ((_currentIndex + 1) * 100d) / OrderedSteps.Count;
    private string CurrentStepClass => IsCurrentStepCompleted ? "cook-step is-complete" : "cook-step";

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _recipe = await Recipes.GetByIdAsync(Id);
        _plannedRecipe = null;
        if (_recipe is not null && PlannedMealId is int plannedMealId)
        {
            var plannedRecipe = await Planner.GetPlannedRecipeAsync(plannedMealId);
            if (plannedRecipe?.RecipeId == _recipe.Id)
            {
                _plannedRecipe = plannedRecipe;
            }
        }

        _displayServings = _plannedRecipe?.PlannedServings > 0
            ? _plannedRecipe.PlannedServings
            : QueryServings is > 0
                ? QueryServings.Value
                : _recipe?.Servings > 0
                    ? _recipe.Servings
                    : 1;
        _currentIndex = 0;
        _isFinished = false;
        _completedStepIds.Clear();
        _isLoading = false;
    }

    private void PreviousStep()
    {
        if (!IsFirstStep)
        {
            _currentIndex--;
        }
    }

    private void NextStep()
    {
        if (!IsLastStep)
        {
            _currentIndex++;
        }
    }

    private void CompleteCurrentStep()
    {
        if (IsLastStep)
        {
            FinishRecipe();
            return;
        }

        _completedStepIds.Add(CurrentStep.Id);
        NextStep();
    }

    private void FinishRecipe()
    {
        foreach (var step in OrderedSteps)
        {
            _completedStepIds.Add(step.Id);
        }

        _isFinished = true;
    }

    private async Task ConfirmInternalNavigationAsync(LocationChangingContext context)
    {
        if (!HasUnfinishedSession)
        {
            return;
        }

        var shouldLeave = await JS.InvokeAsync<bool>(
            "confirm",
            "Vols sortir del mode cuina sense finalitzar la recepta?");

        if (!shouldLeave)
        {
            context.PreventNavigation();
        }
    }
}
