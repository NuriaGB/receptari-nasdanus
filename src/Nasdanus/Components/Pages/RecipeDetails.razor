@page "/recipes/{Id:int}"
@inject RecipeService Recipes
@inject PlannerService Planner

<PageTitle>@(_recipe is null ? "Recepta" : _recipe.Name)</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="page-shell recipe-detail-shell">
    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_recipe is null)
    {
        <MudAlert Severity="Severity.Warning">No s'ha trobat la recepta.</MudAlert>
    }
    else
    {
        <MudStack Spacing="3">
            <MudButton Href="/recipes"
                       Variant="Variant.Text"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.ArrowBack">
                Receptes
            </MudButton>

            <div class="page-heading recipe-heading">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Class="recipe-badges">
                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">@CategoryText</MudChip>
                    @if (_recipe.IsDraft)
                    {
                        <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined">Draft</MudChip>
                    }
                </MudStack>
                <MudText Typo="Typo.h3">@_recipe.Name</MudText>
                @if (!string.IsNullOrWhiteSpace(_recipe.Description))
                {
                    <MudText Typo="Typo.body1" Color="Color.Secondary">@_recipe.Description</MudText>
                }
            </div>

            <MudStack Row Class="recipe-actions">
                <MudButton Href="@CookHref"
                           Class="recipe-primary-action"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.Restaurant">
                    Cuinar
                </MudButton>
                <MudButton Href="@($"/recipes/{_recipe.Id}/edit")"
                           Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.Edit">
                    Editar
                </MudButton>
            </MudStack>

            <MudGrid Spacing="2" Class="recipe-meta-grid">
                <MudItem xs="6" sm="3">
                    <MudPaper Class="metric" Elevation="0">
                        <MudText Typo="Typo.overline">Preparació</MudText>
                        <MudText Typo="Typo.h6">@_recipe.PreparationTimeMinutes min</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudPaper Class="metric" Elevation="0">
                        <MudText Typo="Typo.overline">Cocció</MudText>
                        <MudText Typo="Typo.h6">@_recipe.CookingTimeMinutes min</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudPaper Class="metric" Elevation="0">
                        <MudText Typo="Typo.overline">Dificultat</MudText>
                        <MudText Typo="Typo.h6">@_recipe.Difficulty</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudPaper Class="metric" Elevation="0">
                        <MudText Typo="Typo.overline">Racions</MudText>
                        <MudText Typo="Typo.h6">@_recipe.Servings</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudPaper Class="serving-scale-panel" Elevation="0">
                <div>
                    <MudText Typo="Typo.subtitle1">Racions</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Base de la recepta: @_recipe.Servings racions
                    </MudText>
                </div>
                <MudNumericField T="int"
                                 Label="@ServingInputLabel"
                                 @bind-Value="_displayServings"
                                 Min="1"
                                 Disabled="@IsPlannedContext"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Adornment="Adornment.Start"
                                 AdornmentIcon="@Icons.Material.Filled.Groups" />
            </MudPaper>

            <MudPaper Class="detail-section ingredient-section" Elevation="0">
                <MudText Typo="Typo.h5">Ingredients</MudText>
                @if (_recipe.Ingredients.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Encara no hi ha ingredients.</MudText>
                }
                else
                {
                    <MudList T="RecipeIngredient" Dense="true" Class="ingredient-list">
                        @foreach (var ingredient in _recipe.Ingredients.OrderBy(ingredient => ingredient.Order))
                        {
                            <MudListItem Icon="@Icons.Material.Filled.CheckCircleOutline">
                                @ingredient.ToDisplayText(ScaleFactor)
                            </MudListItem>
                        }
                    </MudList>
                }
            </MudPaper>

            <MudPaper Class="detail-section steps-section" Elevation="0">
                <MudText Typo="Typo.h5">Passos</MudText>
                @if (_recipe.Steps.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Encara no hi ha passos.</MudText>
                }
                else
                {
                    <MudStack Spacing="2">
                        @foreach (var step in _recipe.Steps.OrderBy(step => step.Order))
                        {
                            <div class="detail-step">
                                <MudText Typo="Typo.subtitle1">@step.Order. @step.Title</MudText>
                                <MudText Typo="Typo.body1">@step.Instruction</MudText>
                                @if (step.TimerMinutes is not null)
                                {
                                    <MudChip T="string" Color="Color.Tertiary" Variant="Variant.Outlined" Size="Size.Small" Icon="@Icons.Material.Filled.Timer">
                                        @step.TimerMinutes min
                                    </MudChip>
                                }
                            </div>
                        }
                    </MudStack>
                }
            </MudPaper>

            <MudPaper Class="detail-section notes-section" Elevation="0">
                <MudText Typo="Typo.h5">Notes</MudText>
                @if (_recipe.Notes.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Encara no hi ha notes.</MudText>
                }
                else
                {
                    <MudStack Spacing="2">
                        @foreach (var section in RecipeNoteSection.DisplayOrder)
                        {
                            var notes = NotesFor(section);
                            if (notes.Count == 0)
                            {
                                continue;
                            }

                            <div class="recipe-note-section">
                                <MudText Typo="Typo.subtitle1">@RecipeNoteSection.ToDisplayName(section)</MudText>
                                <MudList T="RecipeNote" Dense="true">
                                    @foreach (var note in notes)
                                    {
                                        <MudListItem Icon="@Icons.Material.Filled.StickyNote2">
                                            @note.Content
                                        </MudListItem>
                                    }
                                </MudList>
                            </div>
                        }
                    </MudStack>
                }
            </MudPaper>
        </MudStack>
    }
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    [SupplyParameterFromQuery(Name = "plannedMealId")]
    public int? PlannedMealId { get; set; }

    [SupplyParameterFromQuery(Name = "servings")]
    public int? QueryServings { get; set; }

    private Recipe? _recipe;
    private MealPlanRecipe? _plannedRecipe;
    private bool _isLoading = true;
    private int _displayServings = 1;
    private string CategoryText => string.IsNullOrWhiteSpace(_recipe?.Category) ? "Sense categoria" : _recipe.Category;
    private bool IsPlannedContext => _plannedRecipe is not null;
    private string ServingInputLabel => IsPlannedContext ? "Racions planificades" : "Racions temporals";
    private decimal ScaleFactor => _recipe is null ? 1 : IngredientScaling.ScaleFactor(_recipe.Servings, _displayServings);
    private string CookHref
    {
        get
        {
            if (_recipe is null)
            {
                return "/recipes";
            }

            return IsPlannedContext
                ? $"/cook/{_recipe.Id}?plannedMealId={_plannedRecipe!.Id}"
                : $"/cook/{_recipe.Id}?servings={_displayServings}";
        }
    }

    private IReadOnlyList<RecipeNote> NotesFor(string section) =>
        _recipe?.Notes
            .Where(note => note.Section == section)
            .OrderBy(note => note.Order)
            .ToList() ?? [];

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _recipe = await Recipes.GetByIdAsync(Id);
        _plannedRecipe = null;
        if (_recipe is not null && PlannedMealId is int plannedMealId)
        {
            var plannedRecipe = await Planner.GetPlannedRecipeAsync(plannedMealId);
            if (plannedRecipe?.RecipeId == _recipe.Id)
            {
                _plannedRecipe = plannedRecipe;
            }
        }

        _displayServings = _plannedRecipe?.PlannedServings > 0
            ? _plannedRecipe.PlannedServings
            : QueryServings is > 0
                ? QueryServings.Value
                : _recipe?.Servings > 0
                    ? _recipe.Servings
                    : 1;
        _isLoading = false;
    }
}
