@page "/"
@page "/dashboard"
@inject PlannerService Planner
@inject NutritionService Nutrition

<PageTitle>Nasdanus - Avui</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="page-shell">
    <MudStack Spacing="3">
        <div class="page-heading">
            <MudText Typo="Typo.overline">Avui</MudText>
            <MudText Typo="Typo.h3">Què toca cuinar?</MudText>
        </div>

        @if (_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else
        {
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    @MealCard("Dinar d'avui", _lunch)
                </MudItem>
                <MudItem xs="12" sm="6">
                    @MealCard("Sopar d'avui", _dinner)
                </MudItem>
            </MudGrid>

            @if (_tomorrowReminders.Count > 0)
            {
                <MudPaper Class="tomorrow-prep" Elevation="0">
                    <MudStack Spacing="2">
                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.EventRepeat" Color="Color.Primary" />
                            <MudText Typo="Typo.h5">Preparar demà</MudText>
                        </MudStack>
                        <MudList T="TomorrowPrepReminder" Dense="true" Class="prep-list">
                            @foreach (var reminder in _tomorrowReminders)
                            {
                                <MudListItem Icon="@reminder.Icon">
                                    <div class="tomorrow-reminder">
                                        <MudText Typo="Typo.subtitle2">@reminder.Title</MudText>
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@reminder.Detail</MudText>
                                    </div>
                                </MudListItem>
                            }
                        </MudList>
                    </MudStack>
                </MudPaper>
            }

            <MudPaper Class="week-summary" Elevation="0">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Class="week-summary-content">
                    <MudIcon Icon="@Icons.Material.Filled.Insights" Color="Color.Primary" Size="Size.Small" />
                    <MudText Typo="Typo.body2">Peix 0/2 · Llegums 0/1 · Verdures 0/7 · Proteïna baixa</MudText>
                </MudStack>
            </MudPaper>

            <MudPaper Class="weekly-nutrition-card" Elevation="0">
                <MudStack Spacing="2">
                    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="week-summary-content">
                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.MonitorHeart" Color="Color.Primary" Size="Size.Small" />
                            <MudText Typo="Typo.h6">Nutricio setmanal</MudText>
                        </MudStack>
                        @if (_weekNutrition?.Totals.HasKnownNutrition == true)
                        {
                            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">
                                @_weekNutrition.Totals.KnownIngredientCount ingredients
                            </MudChip>
                        }
                    </MudStack>

                    @if (_weekNutrition is not null)
                    {
                        <div class="nutrition-metric-grid">
                            @NutritionMetric("Calories", _weekNutrition.Totals.CaloriesKcal, "kcal", WeeklyCaloriesDisplayCap)
                            @NutritionMetric("Proteina", _weekNutrition.Totals.ProteinGrams, "g", WeeklyProteinDisplayCap)
                            @NutritionMetric("Hidrats", _weekNutrition.Totals.CarbohydrateGrams, "g", WeeklyCarbohydrateDisplayCap)
                            @NutritionMetric("Greix", _weekNutrition.Totals.FatGrams, "g", WeeklyFatDisplayCap)
                        </div>

                        @if (!_weekNutrition.Totals.HasKnownNutrition)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                La nutricio apareixera quan completis les dades dels ingredients.
                            </MudText>
                        }
                    }
                </MudStack>
            </MudPaper>

            <MudPaper Class="future-reminders" Elevation="0">
                <MudStack Spacing="2">
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.NotificationsActive" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.h6">Recordatoris</MudText>
                    </MudStack>
                    <MudList T="string" Dense="true" Class="future-reminder-list">
                        @foreach (var reminder in _futureReminders)
                        {
                            <MudListItem Icon="@Icons.Material.Filled.Circle">
                                @reminder
                            </MudListItem>
                        }
                    </MudList>
                </MudStack>
            </MudPaper>

            <MudStack Row Class="home-actions">
                <MudButton Href="planner"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.CalendarMonth">
                    Obrir planner
                </MudButton>
                <MudButton Href="recipes"
                           Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.MenuBook">
                    Receptes
                </MudButton>
            </MudStack>
        }
    </MudStack>
</MudContainer>

@code {
    private MealPlanSlot? _lunch;
    private MealPlanSlot? _dinner;
    private WeekNutritionSummary? _weekNutrition;
    private IReadOnlyList<TomorrowPrepReminder> _tomorrowReminders = [];
    private bool _isLoading = true;
    private const decimal WeeklyCaloriesDisplayCap = 14000;
    private const decimal WeeklyProteinDisplayCap = 420;
    private const decimal WeeklyCarbohydrateDisplayCap = 1750;
    private const decimal WeeklyFatDisplayCap = 540;
    private readonly string[] _futureReminders =
    [
        "Recorda treure pollastre del congelador demà.",
        "Posa cigrons en remull aquesta nit.",
        "Objectiu de peix de la setmana encara pendent."
    ];

    protected override async Task OnInitializedAsync()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var tomorrow = today.AddDays(1);
        _lunch = await Planner.GetSlotAsync(today, MealKind.Lunch);
        _dinner = await Planner.GetSlotAsync(today, MealKind.Dinner);
        var tomorrowLunch = await Planner.GetSlotAsync(tomorrow, MealKind.Lunch);
        var tomorrowDinner = await Planner.GetSlotAsync(tomorrow, MealKind.Dinner);
        _tomorrowReminders = BuildTomorrowReminders(tomorrowLunch, tomorrowDinner);
        _weekNutrition = await Nutrition.CalculateWeekAsync(today);
        _isLoading = false;
    }

    private static string TimeText(Recipe recipe)
    {
        var total = recipe.PreparationTimeMinutes + recipe.CookingTimeMinutes;
        return $"{recipe.PreparationTimeMinutes} min prep. · {recipe.CookingTimeMinutes} min cocció · {total} min total";
    }

    private static string MealCardClass(MealPlanSlot? slot) =>
        slot?.PlannedRecipes.Count is not > 0 ? "meal-card is-empty" : "meal-card";

    private static IReadOnlyList<TomorrowPrepReminder> BuildTomorrowReminders(params MealPlanSlot?[] slots)
    {
        var reminders = new List<TomorrowPrepReminder>();
        var plannedSlots = slots
            .Where(slot => slot?.PlannedRecipes.Count > 0)
            .Select(slot => slot!)
            .ToList();

        foreach (var slot in plannedSlots)
        {
            var recipeNames = slot.PlannedRecipes
                .OrderBy(plannedRecipe => plannedRecipe.Order)
                .Select(plannedRecipe => plannedRecipe.Recipe?.Name)
                .Where(name => !string.IsNullOrWhiteSpace(name))
                .Select(name => name!)
                .ToList();

            if (recipeNames.Count == 0)
            {
                continue;
            }

            reminders.Add(new TomorrowPrepReminder(
                $"{slot.MealKind.ToDisplayName()} de dema",
                string.Join(" + ", recipeNames),
                Icons.Material.Filled.Restaurant));
        }

        var freezerIngredients = plannedSlots
            .SelectMany(slot => slot.PlannedRecipes)
            .Select(plannedRecipe => plannedRecipe.Recipe)
            .Where(recipe => recipe is not null)
            .SelectMany(recipe => recipe!.Ingredients)
            .Where(MightNeedDefrost)
            .Select(ingredient => ingredient.DisplayName.Trim())
            .Where(name => !string.IsNullOrWhiteSpace(name))
            .Distinct(StringComparer.CurrentCultureIgnoreCase)
            .Take(6)
            .ToList();

        if (freezerIngredients.Count > 0)
        {
            reminders.Add(new TomorrowPrepReminder(
                "Possible descongelacio",
                string.Join(", ", freezerIngredients),
                Icons.Material.Filled.AcUnit));
        }

        if (plannedSlots.Count > 0)
        {
            reminders.Add(new TomorrowPrepReminder(
                "Revisa compra",
                "Comprova que tens els ingredients dels apats de dema.",
                Icons.Material.Filled.ShoppingCart));
        }

        return reminders;
    }

    private static bool MightNeedDefrost(RecipeIngredient ingredient) =>
        ingredient.Ingredient?.CanFreeze == true
        || ContainsAny(
            ingredient.DisplayName,
            "pollastre",
            "chicken",
            "vedella",
            "beef",
            "porc",
            "pork",
            "peix",
            "fish",
            "salmo",
            "bacalla",
            "gamba",
            "lluc",
            "llagosti",
            "marisc");

    private static bool ContainsAny(string value, params string[] fragments) =>
        fragments.Any(fragment => value.Contains(fragment, StringComparison.CurrentCultureIgnoreCase));

    private RenderFragment MealCard(string title, MealPlanSlot? slot) => @<MudPaper Class="@MealCardClass(slot)" Elevation="0">
        <MudStack Spacing="2">
            <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.h5">@title</MudText>
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">Planificat</MudChip>
            </MudStack>

            @if (slot?.PlannedRecipes.Count is not > 0)
            {
                <MudText Typo="Typo.h6">Sense recepta assignada</MudText>
                <MudButton Href="planner"
                           Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.CalendarMonth">
                    Obrir planner
                </MudButton>
            }
            else
            {
                @foreach (var plannedRecipe in slot.PlannedRecipes.OrderBy(plannedRecipe => plannedRecipe.Order))
                {
                    if (plannedRecipe.Recipe is not null)
                    {
                        <div class="home-planned-recipe">
                            <MudText Typo="Typo.h5" Class="meal-title">@plannedRecipe.Recipe.Name</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@TimeText(plannedRecipe.Recipe)</MudText>
                            <MudButton Href="@($"recipes/{plannedRecipe.Recipe.Id}")"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Medium"
                                       StartIcon="@Icons.Material.Filled.OpenInNew">
                                Obrir recepta
                            </MudButton>
                        </div>
                    }
                }
            }
        </MudStack>
    </MudPaper>;

    private static RenderFragment NutritionMetric(string label, decimal value, string unit, decimal displayCap) => @<div class="nutrition-metric">
        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.body2">@label</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@($"{value:0} {unit}")</MudText>
        </MudStack>
        <MudProgressLinear Value="@ProgressValue(value, displayCap)" Color="Color.Primary" Rounded="true" Class="nutrition-progress" />
    </div>;

    private static double ProgressValue(decimal value, decimal displayCap) =>
        displayCap <= 0 ? 0 : Math.Min(100, (double)(value / displayCap * 100));

    private sealed record TomorrowPrepReminder(string Title, string Detail, string Icon);
}
