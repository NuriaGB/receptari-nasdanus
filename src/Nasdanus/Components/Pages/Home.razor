@page "/"
@inject PlannerService Planner

<PageTitle>Nasdanus - Avui</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="page-shell">
    <MudStack Spacing="3">
        <div class="page-heading">
            <MudText Typo="Typo.overline">Avui</MudText>
            <MudText Typo="Typo.h3">Què toca cuinar?</MudText>
        </div>

        @if (_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else
        {
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    @MealCard("Dinar d'avui", _lunch)
                </MudItem>
                <MudItem xs="12" sm="6">
                    @MealCard("Sopar d'avui", _dinner)
                </MudItem>
            </MudGrid>

            @if (_tomorrowReminders.Length > 0)
            {
                <MudPaper Class="tomorrow-prep" Elevation="0">
                    <MudStack Spacing="2">
                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.EventRepeat" Color="Color.Primary" />
                            <MudText Typo="Typo.h5">Preparar demà</MudText>
                        </MudStack>
                        <MudList T="string" Dense="true" Class="prep-list">
                            @foreach (var reminder in _tomorrowReminders)
                            {
                                <MudListItem Icon="@Icons.Material.Filled.CheckCircleOutline">
                                    @reminder
                                </MudListItem>
                            }
                        </MudList>
                    </MudStack>
                </MudPaper>
            }

            <MudPaper Class="week-summary" Elevation="0">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Class="week-summary-content">
                    <MudIcon Icon="@Icons.Material.Filled.Insights" Color="Color.Primary" Size="Size.Small" />
                    <MudText Typo="Typo.body2">Peix 0/2 · Llegums 0/1 · Verdures 0/7 · Proteïna baixa</MudText>
                </MudStack>
            </MudPaper>

            <MudStack Row Class="home-actions">
                <MudButton Href="/planner"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.CalendarMonth">
                    Obrir planner
                </MudButton>
                <MudButton Href="/recipes"
                           Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.MenuBook">
                    Receptes
                </MudButton>
            </MudStack>
        }
    </MudStack>
</MudContainer>

@code {
    private MealPlanSlot? _lunch;
    private MealPlanSlot? _dinner;
    private bool _isLoading = true;
    private readonly string[] _tomorrowReminders =
    [
        "Treu 2 pits de pollastre del congelador",
        "Deixa l'arròs mesurat per al dinar"
    ];

    protected override async Task OnInitializedAsync()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        _lunch = await Planner.GetSlotAsync(today, MealKind.Lunch);
        _dinner = await Planner.GetSlotAsync(today, MealKind.Dinner);
        _isLoading = false;
    }

    private static string TimeText(Recipe recipe)
    {
        var total = recipe.PreparationTimeMinutes + recipe.CookingTimeMinutes;
        return $"{recipe.PreparationTimeMinutes} min prep. · {recipe.CookingTimeMinutes} min cocció · {total} min total";
    }

    private static string MealCardClass(MealPlanSlot? slot) =>
        slot?.PlannedRecipes.Count is not > 0 ? "meal-card is-empty" : "meal-card";

    private RenderFragment MealCard(string title, MealPlanSlot? slot) => @<MudPaper Class="@MealCardClass(slot)" Elevation="0">
        <MudStack Spacing="2">
            <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.h5">@title</MudText>
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">Planificat</MudChip>
            </MudStack>

            @if (slot?.PlannedRecipes.Count is not > 0)
            {
                <MudText Typo="Typo.h6">Sense recepta assignada</MudText>
                <MudButton Href="/planner"
                           Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.CalendarMonth">
                    Obrir planner
                </MudButton>
            }
            else
            {
                @foreach (var plannedRecipe in slot.PlannedRecipes.OrderBy(plannedRecipe => plannedRecipe.Order))
                {
                    if (plannedRecipe.Recipe is not null)
                    {
                        <div class="home-planned-recipe">
                            <MudText Typo="Typo.h5" Class="meal-title">@plannedRecipe.Recipe.Name</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@TimeText(plannedRecipe.Recipe)</MudText>
                            <MudButton Href="@($"/recipes/{plannedRecipe.Recipe.Id}")"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Medium"
                                       StartIcon="@Icons.Material.Filled.OpenInNew">
                                Obrir recepta
                            </MudButton>
                        </div>
                    }
                }
            }
        </MudStack>
    </MudPaper>;
}
